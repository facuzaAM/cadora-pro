# ── App ──────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
APP_NAME=Cadora API

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cadora:your-db-password@db:5432/cadora
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Supabase (Auth + Storage) ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
STORAGE_BUCKET=cadora-documents

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=generate-a-random-secret-with-openssl-rand-64-hex
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── OpenAI (OCR opcional) ────────────────────────────────────
OPENAI_API_KEY=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_BUSINESS=price_business_id
STRIPE_CANCEL_URL=https://app.cadora.pro/billing
STRIPE_SUCCESS_URL=https://app.cadora.pro/billing?success=true

# ── Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["https://app.cadora.pro"]

# ── Trusted Hosts ───────────────────────────────────────────
TRUSTED_HOSTS=localhost,127.0.0.1,api,nginx,cadora.pro,app.cadora.pro,api.cadora.pro

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute

# ── Logging ──────────────────────────────────────────────────
LOG_FILE=/app/logs/app.log
LOG_LEVEL=INFO

# ── Sentry (opcional) ────────────────────────────────────────
SENTRY_DSN=

# ── Postgres (solo docker-compose) ───────────────────────────
POSTGRES_DB=cadora
POSTGRES_USER=cadora
POSTGRES_PASSWORD=changeme
