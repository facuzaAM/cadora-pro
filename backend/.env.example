# ── App ──────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
APP_NAME=Cadora API

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cadora:your-db-password@db:5432/cadora
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Supabase (Auth + Storage) ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
STORAGE_BUCKET=cadora-documents

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=generate-a-random-secret-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── OpenAI (OCR opcional) ────────────────────────────────────
OPENAI_API_KEY=

# ── Paddle Billing (opcional, configurar despues del launch) ──
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_STARTER=
PADDLE_PRICE_PRO=
PADDLE_PRICE_BUSINESS=
PADDLE_ENVIRONMENT=sandbox

# ── Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["https://app.cadora.pro"]

# ── Trusted Hosts ───────────────────────────────────────────
TRUSTED_HOSTS=localhost,127.0.0.1,api,nginx,cadora.pro,app.cadora.pro,api.cadora.pro

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute

# ── Logging ──────────────────────────────────────────────────
LOG_FILE=
LOG_LEVEL=INFO

# ── Sentry (opcional) ────────────────────────────────────────
SENTRY_DSN=

# ── Postgres (solo docker-compose) ───────────────────────────
POSTGRES_DB=cadora
POSTGRES_USER=cadora
POSTGRES_PASSWORD=changeme
