# ── Cadora Backend — Production Environment ──────────────────
# Copy this to .env on the VPS and fill in real values.
# NEVER commit the real .env to git.

DEBUG=false
ENVIRONMENT=production

# Database (Docker internal network — uses the db service)
DATABASE_URL=postgresql+asyncpg://cadora:${POSTGRES_PASSWORD}@db:5432/cadora

# Supabase (get from supabase.com dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_ANON_KEY

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS

# CORS (all domains the frontend is served from)
CORS_ORIGINS=["https://cadora.pro","https://app.cadora.pro","https://api.cadora.pro"]

# Paddle Billing (from paddle.com dashboard)
PADDLE_API_KEY=paddle_api_key_xxx
PADDLE_WEBHOOK_SECRET=whsec_xxx
PADDLE_CLIENT_TOKEN=ptk_xxx
PADDLE_PRICE_STARTER=price_starter_id
PADDLE_PRICE_PRO=price_pro_id
PADDLE_PRICE_BUSINESS=price_business_id
PADDLE_ENVIRONMENT=production

# Upload limits
MAX_FILE_SIZE_MB=50

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_DETECTION=10/minute
RATE_LIMIT_CAD=5/minute

# Logging
LOG_FILE=
LOG_LEVEL=INFO

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.cadora.pro/api/v1/auth/google/callback

# SMTP — password reset emails (leave SMTP_HOST empty to log emails in dev)
SMTP_HOST=              # e.g. smtp.resend.com, smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=hello@cadora.pro
EMAIL_FROM_NAME=Cadora
